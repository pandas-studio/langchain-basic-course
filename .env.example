# =====================================================================
# 생성형 AI / LLM 입문 강의 — 환경변수 예시
# 사용법: 이 파일을 `.env` 로 복사한 뒤, 사용할 옵션의 키만 채우면 됩니다.
# 3개 중 1개만 있어도 강의를 끝까지 진행할 수 있습니다.
# =====================================================================

# ✅ Option 1: Google Gemini (추천 — 무료, 카드 등록 불필요)
# 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ✅ Option 2: Groq (무료, 매우 빠름, Qwen3 32B 한국어 우수)
# 발급: https://console.groq.com/keys
GROQ_API_KEY=

# ✅ Option 3: Ollama (완전 무료, 로컬)
# 설치: https://ollama.com  → 터미널에서 `ollama pull gemma4:e4b`
# 별도 API 키 불필요. 로컬 11434 포트 자동 사용.

# ⚙️ Option 4: OpenAI (선택, 유료 — 카드 등록 필요)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 🔎 04 Tools 노트북 — Tavily 웹 검색 (무료 한도 1,000회/월)
# 발급: https://app.tavily.com
TAVILY_API_KEY=

# 📊 (선택) LangSmith 추적 — 디버깅용
# 발급: https://smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=langchain-basic-course-2026
